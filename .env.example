# Chrome / CDP
CDP_URL=http://127.0.0.1:9226
CHROME_PROFILE_DIR=~/.config/google-chrome-tingwu
CHROME_DISPLAY=:10

# Tingwu
TINGWU_STATE_FILE=~/.config/yt-transcribe-feishu/tingwu_state.json
# Transcription wait depends on audio length; 24min video needs ~3-4min.
TINGWU_TRANSCRIBE_TIMEOUT=600
TINGWU_POLL_INTERVAL=5

# Feishu
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-app-secret
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxx
FEISHU_GROUP_NOTIFY=1
FEISHU_GROUP_ONLY=0

# Pipeline
RUN_CMD_TIMEOUT=180
YOUTUBE_CHANNELS_CONFIG=./config/channels.json
YOUTUBE_RSS_STATE_FILE=./data/processed.json
LOG_LEVEL=INFO
